---
import { Code } from "astro:components";

interface Props {
  html: string;
  css?: string;
  assets?: Record<string, string>;
}

const { html, css, assets = {} } = Astro.props;

function resolveAssets(
  code: string,
  assetsMap: Record<string, string>,
): string {
  let result = code;
  for (const [filename, url] of Object.entries(assetsMap)) {
    const escaped = filename.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    result = result.replace(
      new RegExp(`(src=")${escaped}(")`, "g"),
      `$1${url}$2`,
    );
    result = result.replace(
      new RegExp(`(href=")${escaped}(")`, "g"),
      `$1${url}$2`,
    );
    result = result.replace(
      new RegExp(`(url\\(\\s*['"])${escaped}(['"]\\s*\\))`, "g"),
      `$1${url}$2`,
    );
    result = result.replace(
      new RegExp(`(url\\()${escaped}(\\))`, "g"),
      `$1${url}$2`,
    );
  }
  return result;
}

const resolvedHtml = resolveAssets(html, assets);
const resolvedCss = css ? resolveAssets(css, assets) : "";

const hasInlineStyle = /<style[\s>]/i.test(resolvedHtml);

const srcdoc =
  !hasInlineStyle && resolvedCss
    ? resolvedHtml.includes("<head>")
      ? resolvedHtml.replace("<head>", `<head><style>${resolvedCss}</style>`)
      : `<html><head><style>${resolvedCss}</style></head><body>${resolvedHtml}</body></html>`
    : resolvedHtml;
---

<div class={`playground-grid ${!css ? "no-css" : ""}`}>
  <div class="preview-column">
    <div class="label">Vista Previa (Navegador)</div>
    <iframe srcdoc={srcdoc}></iframe>
  </div>

  <div class="html-column">
    <div class="label">(HTML)</div>
    <div class="scroll-wrapper">
      <Code code={html} lang="html" theme="github-light" />
    </div>
  </div>

  {
    css !== undefined && (
      <div class="css-column">
        <div class="label">(CSS)</div>
        <div class="scroll-wrapper">
          <Code code={css} lang="css" theme="github-light" />
        </div>
      </div>
    )
  }
</div>

<style>
  .playground-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 60% 1fr;
    gap: 2px;
    background: #333;
    border: 1px solid #333;
    border-radius: 10px;
    overflow: hidden;
    margin: 2rem 0;
    height: 1000px;
  }

  .playground-grid.no-css {
    grid-template-columns: 1fr;
  }

  .preview-column {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    background: white;
    overflow: hidden;
    min-height: 0;
  }

  .html-column,
  .css-column {
    display: flex;
    flex-direction: column;
    background: #1e1e1e;
    overflow: hidden;
  }

  .scroll-wrapper {
    overflow: auto;
    flex-grow: 1;
  }

  iframe {
    flex-grow: 1;
    width: 100%;
    border: none;
  }

  .label {
    padding: 8px 15px;
    font-size: 0.7rem;
    background: #9f9f9f;
    color: #363636;
    font-weight: bold;
    border-bottom: 1px solid #363636;
  }
</style>
